{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        // The "Launch Package" configuration is used to debug the entire Go package in the workspace folder.
        // It sets the program to "${workspaceFolder}", so it will run the main package at the root of your project.
        // The "cwd" property sets the current working directory for the debug session.
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "program": "${workspaceFolder}/cmd/server/main.go",
            "cwd": "${workspaceFolder}"
        }
    ]
}